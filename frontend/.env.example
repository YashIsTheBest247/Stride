# Local dev: the vite proxy sends /api → http://localhost:8000 (see vite.config.ts)
# Leave this as the default and skip creating a .env in dev.
VITE_API_BASE=/api

# Production (Vercel): set the full deployed backend URL in the Vercel dashboard,
# Project Settings → Environment Variables. Example:
#   VITE_API_BASE=https://stride-backend.onrender.com/api
