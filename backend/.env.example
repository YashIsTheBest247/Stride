# LLM provider — Google Gemini (free tier).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
# Auto-fallback when the primary returns 503/UNAVAILABLE after all retries.
# Different capacity pool — usually has headroom when 2.5-flash is overloaded.
# Leave empty to disable the fallback.
GEMINI_MODEL_FALLBACK=gemini-2.5-flash-lite

# Tectonic binary path. Leave as "tectonic" if it's on PATH.
TECTONIC_BIN=tectonic

# CORS — comma-separated origins. * is fine for local dev.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Server
HOST=0.0.0.0
PORT=8000
