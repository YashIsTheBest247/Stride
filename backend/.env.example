# LLM provider — Google Gemini (free tier).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Job-search aggregator (OPTIONAL — leave empty to use only free
# Greenhouse/Lever boards). JSearch on RapidAPI covers LinkedIn, Indeed,
# Glassdoor, ZipRecruiter in one API.
# Sign up: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Free tier: 100 requests/month. Basic: $30/mo for 10k.
RAPIDAPI_KEY=

# Tectonic binary path. Leave as "tectonic" if it's on PATH.
TECTONIC_BIN=tectonic

# CORS — comma-separated origins. * is fine for local dev.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Server
HOST=0.0.0.0
PORT=8000
